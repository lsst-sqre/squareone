{
  "name": "@lsst-sqre/squared",
  "description": "A React component library for Squareone / Rubin Data Management.",
  "version": "0.15.1",
  "private": true,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./components/*": "./src/components/*"
  },
  "sideEffects": false,
  "license": "MIT",
  "files": [
    "src/**"
  ],
  "scripts": {
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts*\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .turbo && rm -rf node_modules",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "vitest run --project=storybook",
    "test-storybook:watch": "vitest watch --project=storybook",
    "new-component": "new-component"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@fontsource/source-sans-pro": "^4.5.11",
    "@lsst-sqre/global-css": "workspace:*",
    "@lsst-sqre/rubin-style-dictionary": "workspace:*",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.0.5",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.7",
    "@radix-ui/react-visually-hidden": "^1.2.4",
    "@tanstack/react-table": "^8.21.3",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "^0.563.0",
    "react": "^19.2.7",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.7",
    "swr": "^2.3.8",
    "unfetch": "^4.2.0"
  },
  "devDependencies": {
    "@lsst-sqre/eslint-config": "workspace:*",
    "@lsst-sqre/tsconfig": "workspace:*",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-links": "10.4.6",
    "@storybook/addon-onboarding": "10.4.6",
    "@storybook/addon-themes": "10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@storybook/testing-library": "^0.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.1.0",
    "eslint": "^9.26.0",
    "eslint-plugin-storybook": "10.4.6",
    "glob": "^13.0.3",
    "msw": "2.12.9",
    "msw-storybook-addon": "^2.0.7",
    "new-component": "^5.0.2",
    "next": "^16.2.10",
    "playwright": "^1.61.1",
    "react-hook-form": "^7.71.1",
    "storybook": "10.4.6",
    "typescript": "^5.9.3",
    "typescript-plugin-css-modules": "^5.0.1",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "next": "16",
    "react": "19",
    "react-dom": "19"
  },
  "msw": {
    "workerDirectory": "public"
  },
  "jest": {
    "roots": [
      "src"
    ]
  }
}
